{
  "name": "sistema-registros",
  "private": true,
  "version": "1.0.8",
  "packageManager": "pnpm@10.12.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && node scripts/persist-vite-build-seq.mjs",
    "build:prod": "node scripts/build-production.mjs",
    "check:utf8": "node scripts/validate-utf8.mjs",
    "check:invariants": "node scripts/check-regression-invariants.mjs",
    "snapshot:critical": "node scripts/snapshot-critical-files.mjs",
    "agent:finish": "node scripts/agent-session-finish.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "migrate:vnpm-ids": "node scripts/migrate_participant_doc_ids_to_vnpm.mjs",
    "lint": "eslint .",
    "preview": "vite preview",
    "generate:pwa-icon": "node scripts/generate-pwa-icon.mjs",
    "deploy:firestore": "node scripts/deploy-firestore.mjs",
    "bump:client-reload": "node scripts/bump-client-reload-nonce.mjs",
    "deploy:hosting": "node scripts/deploy-hosting.mjs",
    "deploy:hosting:skip-build": "node scripts/deploy-hosting.mjs --skip-build"
  },
  "dependencies": {
    "firebase": "^12.12.1",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.577.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.14.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "firebase-admin": "^13.8.0",
    "firebase-tools": "^14.11.0",
    "globals": "^17.4.0",
    "postcss": "^8.5.8",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.19",
    "vite": "^8.0.1",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^3.2.6",
    "workbox-window": "^7.4.0"
  },
  "pnpm": {
    "overrides": {
      "teeny-request": "^10.1.2",
      "@tootallnate/once": "^3.0.1"
    }
  }
}
